# FitTools — environment variables (see README.md for full detail).
# Copy to .env.local for local overrides. All are OFF/unset by default;
# with none set the site makes zero third-party requests.

# --- Go-live / SEO ---------------------------------------------------------
# Canonical origin used in metadata, canonicals, JSON-LD, sitemap and OG links.
# LEAVE UNSET in local dev and Vercel Preview — while unset, every page emits
# `noindex`, so previews can never enter the search index.
# Set in Vercel PRODUCTION ONLY (no trailing slash), then redeploy:
#   NEXT_PUBLIC_SITE_URL=https://tools.fit

# --- Pulse (AI fact feed) --------------------------------------------------
# Without a key, /pulse serves the vetted claims verbatim (degraded, still real).
# Cost is bounded site-wide, never per user: one corpus-wide phrasing pass per
# UTC day on the Haiku default, plus a hard daily call budget (PULSE.md §14.1).
# ANTHROPIC_API_KEY=
# PULSE_LLM_MODEL=claude-opus-4-8      # optional override of the claude-haiku-4-5 default
# PULSE_LLM_PROVIDER=none              # forces degraded mode

# --- Monetisation infrastructure (M3 — all consent-gated, off by default) --
# NEXT_PUBLIC_GA4_ID=                  # GA4, loads only after consent
# NEXT_PUBLIC_CMP_SCRIPT_URL=          # Google-certified CMP (required before ads)
# NEXT_PUBLIC_ADS_SCRIPT_URL=          # ad network script, loads only after consent
# NEXT_PUBLIC_ADS_ENABLED=false        # "true" lets AdSlot render (still consent-gated)

# --- Email capture ---------------------------------------------------------
# NEXT_PUBLIC_EMAIL_ENDPOINT=          # newsletter endpoint (provider must do double opt-in)

# --- Accounts (ACCOUNTS.md — A0 provisioning; ALL unset = accounts off, ---
# --- the site runs byte-identical signed-out, auth routes return 503) ------
# Neon Postgres connection string (UK/EU region — London preferred; run
# db/schema.sql + the Better Auth CLI migration once at provisioning):
# DATABASE_URL=
# 32+ char secret for session signing (openssl rand -base64 32):
# BETTER_AUTH_SECRET=
# Only needed if auth must run on a non-canonical origin (previews):
# BETTER_AUTH_URL=
# Resend — magic-link email (sender domain needs SPF/DKIM/DMARC first):
# RESEND_API_KEY=
# AUTH_EMAIL_FROM="FitTools <sign-in@tools.fit>"
# Google OAuth (console.cloud.google.com — web client):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Sign in with Apple (developer.apple.com — Services ID + key):
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
